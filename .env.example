# ── Azure Document Intelligence ───────────────────────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=<your-api-key>

# Model ID to use: prebuilt-layout | prebuilt-invoice | prebuilt-document | prebuilt-read
# prebuilt-layout is the most general — works well for PDFs, images, and engineering drawings
AZURE_DI_MODEL_ID=prebuilt-layout

# ── Anthropic (Claude Vision) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_MODEL=claude-opus-4-6

# ── Extraction backend ─────────────────────────────────────────────────────────
# Which extractor to use by default: azure | claude | vision
DEFAULT_EXTRACTOR=azure

# ── Paths ──────────────────────────────────────────────────────────────────────
INPUT_DIR=inputs/
OUTPUT_DIR=outputs/
